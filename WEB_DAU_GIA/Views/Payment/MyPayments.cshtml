@using WEB_DAU_GIA.Models.ViewModels
@model List<PaymentViewModel>

@{
    ViewData["Title"] = "Thanh toán của tôi";
    Layout = "_DashboardLayout";
}

<div class="container-fluid">
    <!-- Header -->
    <div class="mb-4">
        <h2 class="fw-bold mb-1">
            <i class="fas fa-credit-card me-2"></i>Thanh toán của tôi
        </h2>
        <p class="text-secondary mb-0">Lịch sử tất cả các giao dịch thanh toán</p>
    </div>

    <!-- Statistics Cards -->
    <div class="row g-4 mb-4">
        <div class="col-lg-3 col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <div class="bg-success bg-opacity-10 rounded-circle p-3">
                                <i class="fas fa-check-circle fa-2x text-success"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h6 class="text-muted mb-1">Đã thanh toán</h6>
                            <h3 class="fw-bold mb-0">@Model.Count(p => p.PaymentStatus == "completed")</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <div class="bg-warning bg-opacity-10 rounded-circle p-3">
                                <i class="fas fa-clock fa-2x text-warning"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h6 class="text-muted mb-1">Đang chờ</h6>
                            <h3 class="fw-bold mb-0">@Model.Count(p => p.PaymentStatus == "pending")</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <div class="bg-info bg-opacity-10 rounded-circle p-3">
                                <i class="fas fa-dollar-sign fa-2x text-info"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h6 class="text-muted mb-1">Tổng chi tiêu</h6>
                            <h3 class="fw-bold mb-0">
                                $@Model.Where(p => p.PaymentStatus == "completed").Sum(p => p.Amount).ToString("N0")
                            </h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <div class="bg-primary bg-opacity-10 rounded-circle p-3">
                                <i class="fas fa-receipt fa-2x text-primary"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h6 class="text-muted mb-1">Tổng giao dịch</h6>
                            <h3 class="fw-bold mb-0">@Model.Count</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Filter Tabs -->
    <ul class="nav nav-pills mb-4" id="statusFilter">
        <li class="nav-item">
            <button class="nav-link active" data-status="all">Tất cả (@Model.Count)</button>
        </li>
        <li class="nav-item">
            <button class="nav-link" data-status="completed">
                Đã hoàn thành (@Model.Count(p => p.PaymentStatus == "completed"))
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" data-status="pending">
                Đang chờ (@Model.Count(p => p.PaymentStatus == "pending"))
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" data-status="StartingBid">
                Phí khởi điểm (@Model.Count(p => p.Type == "StartingBid"))
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" data-status="AuctionPurchase">
                Mua đấu giá (@Model.Count(p => p.Type == "AuctionPurchase"))
            </button>
        </li>
    </ul>

    <!-- Payments List -->
    @if (Model.Any())
    {
        <div id="paymentsContainer">
            @foreach (var payment in Model.OrderByDescending(p => p.UpdatedAt))
            {
                <div class="card border-0 shadow-sm mb-3 payment-card"
                     data-status="@payment.PaymentStatus"
                     data-type="@payment.Type">
                    <div class="card-body">
                        <div class="row g-3">
                            <!-- Auction Image -->
                            <div class="col-md-2">
                                <a href="@Url.Action("Details", "Auction", new { id = payment.Auction.AuctionId })">
                                    <img src="@payment.Auction.AuctionImage"
                                         class="img-fluid rounded"
                                         alt="@payment.Auction.Title"
                                         style="width: 100%; height: 120px; object-fit: cover;">
                                </a>
                            </div>

                            <!-- Payment Info -->
                            <div class="col-md-6">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h5 class="fw-bold mb-0">
                                        <a href="@Url.Action("Details", "Auction", new { id = payment.Auction.AuctionId })"
                                           class="text-decoration-none text-dark">
                                            @payment.Auction.Title
                                        </a>
                                    </h5>
                                    <span class="badge bg-@(payment.PaymentStatus == "completed" ? "success" : payment.PaymentStatus == "pending" ? "warning" : "secondary")">
                                        @(payment.PaymentStatus == "completed" ? "Đã hoàn thành" : payment.PaymentStatus == "pending" ? "Đang chờ" : payment.PaymentStatus)
                                    </span>
                                </div>

                                <p class="text-secondary small mb-2">@payment.Auction.Description</p>

                                <div class="row g-2 mb-2">
                                    <div class="col-6">
                                        <small class="text-muted d-block">Loại thanh toán:</small>
                                        <span class="badge bg-@(payment.Type == "StartingBid" ? "info" : "primary")">
                                            <i class="fas fa-@(payment.Type == "StartingBid" ? "play-circle" : "shopping-cart") me-1"></i>
                                            @(payment.Type == "StartingBid" ? "Phí khởi điểm" : "Mua đấu giá")
                                        </span>
                                    </div>
                                    <div class="col-6">
                                        <small class="text-muted d-block">Phương thức:</small>
                                        <strong>@payment.PaymentMethod</strong>
                                    </div>
                                </div>

                                <small class="text-muted">
                                    <i class="fas fa-calendar me-1"></i>
                                    @payment.UpdatedAt.ToString("dd/MM/yyyy HH:mm:ss")
                                </small>
                            </div>

                            <!-- Amount & Actions -->
                            <div class="col-md-4">
                                <div class="text-end">
                                    <small class="text-muted d-block mb-1">Số tiền</small>
                                    <h3 class="text-success fw-bold mb-3">$@payment.Amount.ToString("N2")</h3>

                                    @if (payment.Type == "AuctionPurchase" && payment.PaymentStatus == "completed")
                                    {
                                        <div class="alert alert-success border-0 mb-3">
                                            <i class="fas fa-trophy me-2"></i>
                                            <small>Bạn đã mua thành công đấu giá này!</small>
                                        </div>
                                    }

                                    @if (payment.Type == "StartingBid")
                                    {
                                        <div class="alert alert-info border-0 mb-3">
                                            <i class="fas fa-info-circle me-2"></i>
                                            <small>
                                                Phí này sẽ được hoàn lại nếu bạn không thắng đấu giá.
                                            </small>
                                        </div>
                                    }

                                    <a href="@Url.Action("Details", "Auction", new { id = payment.Auction.AuctionId })"
                                       class="btn btn-outline-primary w-100">
                                        <i class="fas fa-eye me-2"></i>Xem đấu giá
                                    </a>

                                    @if (payment.PaymentStatus == "completed")
                                    {
                                        <button class="btn btn-outline-secondary w-100 mt-2"
                                                onclick="downloadReceipt(@payment.PaymentId)">
                                            <i class="fas fa-download me-2"></i>Tải hóa đơn
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- Auction Details (collapsed) -->
                        <div class="mt-3 pt-3 border-top">
                            <button class="btn btn-sm btn-link text-decoration-none"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#details@(payment.PaymentId)">
                                <i class="fas fa-chevron-down me-1"></i>Xem chi tiết đấu giá
                            </button>
                            <div class="collapse mt-2" id="details@(payment.PaymentId)">
                                <div class="row g-2 text-secondary small">
                                    <div class="col-md-4">
                                        <strong>Danh mục:</strong> @payment.Auction.AuctionCategory
                                    </div>
                                    <div class="col-md-4">
                                        <strong>Giá khởi điểm:</strong> $@payment.Auction.StartingBid
                                    </div>
                                    <div class="col-md-4">
                                        <strong>Trạng thái đấu giá:</strong>
                                        <span class="badge bg-@(payment.Auction.Status == "active" ? "success" : "secondary")">
                                            @(payment.Auction.Status == "active" ? "Đang hoạt động" : "Đã đóng")
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="fas fa-receipt fa-4x text-secondary mb-3 opacity-25"></i>
            <h4 class="text-secondary mb-3">Không có giao dịch nào</h4>
            <p class="text-muted mb-4">Bạn chưa thực hiện thanh toán nào</p>
            <a href="@Url.Action("Index", "Auction")" class="btn btn-primary btn-lg">
                <i class="fas fa-search me-2"></i>Tìm đấu giá
            </a>
        </div>
    }
</div>

@section Scripts {
    <script>
        // Filter functionality
        const filterButtons = document.querySelectorAll('#statusFilter button');
        const paymentCards = document.querySelectorAll('.payment-card');

        filterButtons.forEach(button => {
            button.addEventListener('click', function() {
                filterButtons.forEach(btn => btn.classList.remove('active'));
                this.classList.add('active');

                const filterValue = this.dataset.status;

                paymentCards.forEach(card => {
                    const cardStatus = card.dataset.status;
                    const cardType = card.dataset.type;

                    if (filterValue === 'all') {
                        card.style.display = '';
                    } else if (filterValue === 'StartingBid' || filterValue === 'AuctionPurchase') {
                        card.style.display = cardType === filterValue ? '' : 'none';
                    } else {
                        card.style.display = cardStatus === filterValue ? '' : 'none';
                    }
                });
            });
        });

        // Download receipt
        async function downloadReceipt(paymentId) {
            try {
                const url = `@Url.Action("DownloadReceipt", "Payment")?paymentId=${paymentId}`;
                window.open(url, '_blank');
            } catch (error) {
                alert('Không thể tải hóa đơn. Vui lòng thử lại.');
            }
        }

        // Card hover animation
        document.querySelectorAll('.payment-card').forEach(card => {
            card.addEventListener('mouseenter', function() {
                this.style.transform = 'translateX(5px)';
                this.style.transition = 'transform 0.3s ease';
            });
            card.addEventListener('mouseleave', function() {
                this.style.transform = 'translateX(0)';
            });
        });
    </script>

    <style>
        .payment-card {
            transition: all 0.3s ease;
        }

            .payment-card:hover {
                box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
            }

        .nav-pills .nav-link {
            color: #6c757d;
            border-radius: 50px;
            padding: 0.5rem 1.5rem;
            margin-right: 0.5rem;
            transition: all 0.3s ease;
        }

            .nav-pills .nav-link:hover {
                background-color: rgba(13, 110, 253, 0.1);
                color: #0d6efd;
            }

            .nav-pills .nav-link.active {
                background-color: #0d6efd;
                color: white;
            }
    </style>
}
@using WEB_DAU_GIA.Models.ViewModels
@model CreateAuctionViewModel

@{
    ViewData["Title"] = "Tạo đấu giá mới";
    Layout = "_DashboardLayout";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <!-- Header -->
            <div class="mb-4">
                <h2 class="fw-bold mb-1">
                    <i class="fas fa-plus-circle me-2"></i>Tạo đấu giá mới
                </h2>
                <p class="text-secondary mb-0">Điền thông tin để tạo đấu giá của bạn</p>
            </div>

            <!-- Alert Messages -->
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle me-2"></i>
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-circle me-2"></i>
                    @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <form asp-action="Create" asp-controller="Auction" method="post" enctype="multipart/form-data" id="createAuctionForm">
                @Html.AntiForgeryToken()

                <div class="row g-4">
                    <!-- Left Column - Main Info -->
                    <div class="col-lg-8">
                        <!-- Basic Information Card -->
                        <div class="card border-0 shadow-sm mb-4">
                            <div class="card-header bg-white border-bottom">
                                <h5 class="mb-0 fw-bold">
                                    <i class="fas fa-info-circle me-2"></i>Thông tin cơ bản
                                </h5>
                            </div>
                            <div class="card-body">
                                <!-- Title -->
                                <div class="mb-3">
                                    <label asp-for="Title" class="form-label fw-semibold">
                                        Tiêu đề <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="Title" class="form-control form-control-lg" placeholder="VD: Đồng hồ Rolex cổ điển">
                                    <span asp-validation-for="Title" class="text-danger small"></span>
                                </div>

                                <!-- Description -->
                                <div class="mb-3">
                                    <label asp-for="Description" class="form-label fw-semibold">
                                        Mô tả chi tiết <span class="text-danger">*</span>
                                    </label>
                                    <textarea asp-for="Description" class="form-control" rows="5" placeholder="Mô tả chi tiết về sản phẩm đấu giá..."></textarea>
                                    <span asp-validation-for="Description" class="text-danger small"></span>
                                    <small class="text-muted">Độ dài: <span id="charCount">0</span> ký tự</small>
                                </div>

                                <!-- Category and Starting Bid -->
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label asp-for="AuctionCategory" class="form-label fw-semibold">
                                            Danh mục <span class="text-danger">*</span>
                                        </label>
                                        <select asp-for="AuctionCategory" class="form-select">
                                            <option value="">Chọn danh mục</option>
                                            <option value="Art and Antiques">Nghệ thuật & Đồ cổ</option>
                                            <option value="Fashion and Accessories">Thời trang & Phụ kiện</option>
                                            <option value="Home and Garden">Nhà cửa & Vườn</option>
                                            <option value="Electronics and Gadgets">Điện tử & Công nghệ</option>
                                            <option value="Vehicles">Phương tiện</option>
                                            <option value="Collectibles">Sưu tầm</option>
                                            <option value="Sports and Outdoors">Thể thao & Ngoài trời</option>
                                            <option value="Toys and Games">Đồ chơi & Trò chơi</option>
                                            <option value="Books and Media">Sách & Truyền thông</option>
                                            <option value="Photography">Nhiếp ảnh</option>
                                            <option value="Crafts and Hobbies">Thủ công & Sở thích</option>
                                            <option value="Real Estate">Bất động sản</option>
                                            <option value="Wine and Spirits">Rượu</option>
                                            <option value="Tickets and Experiences">Vé & Trải nghiệm</option>
                                            <option value="Health and Beauty">Sức khỏe & Làm đẹp</option>
                                        </select>
                                        <span asp-validation-for="AuctionCategory" class="text-danger small"></span>
                                    </div>

                                    <div class="col-md-6">
                                        <label asp-for="StartingBid" class="form-label fw-semibold">
                                            Giá khởi điểm (USD) <span class="text-danger">*</span>
                                        </label>
                                        <div class="input-group">
                                            <span class="input-group-text">$</span>
                                            <input asp-for="StartingBid" type="number" class="form-control" placeholder="100" step="10" min="10">
                                        </div>
                                        <span asp-validation-for="StartingBid" class="text-danger small"></span>
                                    </div>
                                </div>

                                <!-- Start Time and End Time -->
                                <div class="row g-3 mt-1">
                                    <div class="col-md-6">
                                        <label asp-for="StartTime" class="form-label fw-semibold">
                                            Ngày bắt đầu <span class="text-danger">*</span>
                                        </label>
                                        <input asp-for="StartTime" type="datetime-local" class="form-control">
                                        <span asp-validation-for="StartTime" class="text-danger small"></span>
                                    </div>

                                    <div class="col-md-6">
                                        <label asp-for="EndTime" class="form-label fw-semibold">
                                            Ngày kết thúc <span class="text-danger">*</span>
                                        </label>
                                        <input asp-for="EndTime" type="datetime-local" class="form-control">
                                        <span asp-validation-for="EndTime" class="text-danger small"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Main Image Upload Card -->
                        <div class="card border-0 shadow-sm mb-4">
                            <div class="card-header bg-white border-bottom">
                                <h5 class="mb-0 fw-bold">
                                    <i class="fas fa-image me-2"></i>Hình ảnh chính <span class="text-danger">*</span>
                                </h5>
                            </div>
                            <div class="card-body">
                                <div class="upload-area" id="mainImageUpload">
                                    <input type="file"
                                           asp-for="MainImage"
                                           accept="image/*"
                                           id="mainImageInput"
                                           class="d-none">
                                    <div class="upload-placeholder text-center p-5" id="mainImagePlaceholder">
                                        <i class="fas fa-cloud-upload-alt fa-3x text-primary mb-3"></i>
                                        <h5>Nhấp để tải lên hình ảnh chính</h5>
                                        <p class="text-muted mb-0">PNG, JPG, JPEG (Tối đa 5MB)</p>
                                    </div>
                                    <div id="mainImagePreview" class="d-none">
                                        <img src="" alt="Preview" class="img-fluid rounded">
                                        <button type="button" class="btn btn-danger btn-sm mt-2" onclick="removeMainImage()">
                                            <i class="fas fa-trash me-1"></i>Xóa
                                        </button>
                                    </div>
                                </div>
                                <span asp-validation-for="MainImage" class="text-danger small"></span>
                            </div>
                        </div>

                        <!-- Additional Images Card -->
                        <div class="card border-0 shadow-sm mb-4">
                            <div class="card-header bg-white border-bottom">
                                <div class="d-flex justify-content-between align-items-center">
                                    <h5 class="mb-0 fw-bold">
                                        <i class="fas fa-images me-2"></i>Hình ảnh bổ sung
                                    </h5>
                                    <button type="button" class="btn btn-sm btn-primary" id="addImageBtn">
                                        <i class="fas fa-plus me-1"></i>Thêm ảnh
                                    </button>
                                </div>
                            </div>
                            <div class="card-body">
                                <p class="text-muted small mb-3">Tối đa 5 hình ảnh bổ sung</p>
                                <div id="additionalImagesContainer"></div>
                            </div>
                        </div>
                    </div>

                    <!-- Right Column - Preview & Actions -->
                    <div class="col-lg-4">
                        <!-- Preview Card -->
                        <div class="card border-0 shadow-sm mb-4 sticky-top" style="top: 20px;">
                            <div class="card-header bg-primary text-white">
                                <h5 class="mb-0">
                                    <i class="fas fa-eye me-2"></i>Xem trước
                                </h5>
                            </div>
                            <div class="card-body">
                                <div id="previewCard">
                                    <div class="preview-image mb-3">
                                        <img src="/images/placeholder.png"
                                             id="previewMainImage"
                                             class="img-fluid rounded"
                                             alt="Preview">
                                    </div>
                                    <h5 id="previewTitle" class="fw-bold">Tiêu đề đấu giá</h5>
                                    <p id="previewDescription" class="text-secondary small">Mô tả sẽ hiển thị ở đây...</p>
                                    <div class="mb-2">
                                        <span class="badge bg-light text-dark border" id="previewCategory">Danh mục</span>
                                    </div>
                                    <div class="d-flex justify-content-between">
                                        <div>
                                            <small class="text-muted d-block">Giá khởi điểm</small>
                                            <strong class="text-success" id="previewBid">$0</strong>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Submit Card -->
                        <div class="card border-0 shadow-sm">
                            <div class="card-body">
                                <button type="submit" class="btn btn-success btn-lg w-100 mb-2" id="submitBtn">
                                    <i class="fas fa-check me-2"></i>Tạo đấu giá
                                </button>
                                <a href="@Url.Action("MyAuctions")" class="btn btn-outline-secondary w-100">
                                    <i class="fas fa-times me-2"></i>Hủy
                                </a>
                                <div class="alert alert-info border-0 mt-3 mb-0">
                                    <small>
                                        <i class="fas fa-info-circle me-1"></i>
                                        Đấu giá sẽ được xem xét trước khi xuất bản.
                                    </small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Loading Overlay -->
<div id="loadingOverlay" class="d-none">
    <div class="text-center">
        <div class="spinner-border text-light mb-3" style="width: 3rem; height: 3rem;" role="status"></div>
        <h5 class="text-white">Đang tải lên...</h5>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        let additionalImageCount = 0;
        const MAX_ADDITIONAL_IMAGES = 5;

        // Character counter
        const descriptionInput = document.querySelector('textarea[name="Description"]');
        const charCount = document.getElementById('charCount');
        descriptionInput.addEventListener('input', function() {
            charCount.textContent = this.value.length;
        });

        // Main image upload
        const mainImageUpload = document.getElementById('mainImageUpload');
        const mainImageInput = document.getElementById('mainImageInput');
        const mainImagePlaceholder = document.getElementById('mainImagePlaceholder');
        const mainImagePreview = document.getElementById('mainImagePreview');

        mainImageUpload.addEventListener('click', function() {
            if (!mainImagePreview.classList.contains('d-none')) return;
            mainImageInput.click();
        });

        mainImageInput.addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                if (file.size > 5 * 1024 * 1024) {
                    alert('Kích thước file không được vượt quá 5MB');
                    return;
                }

                const reader = new FileReader();
                reader.onload = function(event) {
                    mainImagePreview.querySelector('img').src = event.target.result;
                    mainImagePlaceholder.classList.add('d-none');
                    mainImagePreview.classList.remove('d-none');

                    // Update preview
                    document.getElementById('previewMainImage').src = event.target.result;
                };
                reader.readAsDataURL(file);
            }
        });

        function removeMainImage() {
            mainImageInput.value = '';
            mainImagePlaceholder.classList.remove('d-none');
            mainImagePreview.classList.add('d-none');
            document.getElementById('previewMainImage').src = '/images/placeholder.png';
        }

        // Add additional image
        document.getElementById('addImageBtn').addEventListener('click', function() {
            if (additionalImageCount >= MAX_ADDITIONAL_IMAGES) {
                alert('Bạn chỉ có thể thêm tối đa 5 hình ảnh bổ sung');
                return;
            }

            const container = document.getElementById('additionalImagesContainer');
            const index = additionalImageCount;

            const imageCard = document.createElement('div');
            imageCard.className = 'card border mb-3 additional-image-card';
            imageCard.innerHTML = `
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold">Hình ảnh ${index + 1}</label>
                            <input type="file"
                                   name="AdditionalImages[${index}].Image"
                                   accept="image/*"
                                   class="form-control additional-image-input"
                                   data-index="${index}">
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Tên hình ảnh</label>
                            <input type="text"
                                   name="AdditionalImages[${index}].ItemName"
                                   class="form-control"
                                   placeholder="VD: Mặt trước">
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Mô tả (tùy chọn)</label>
                            <textarea name="AdditionalImages[${index}].ItemDescription"
                                      class="form-control"
                                      rows="2"
                                      placeholder="Mô tả ngắn về hình ảnh..."></textarea>
                        </div>
                        <div class="col-12">
                            <button type="button" class="btn btn-sm btn-danger" onclick="removeAdditionalImage(this)">
                                <i class="fas fa-trash me-1"></i>Xóa
                            </button>
                        </div>
                    </div>
                    <div class="mt-2 additional-preview d-none">
                        <img src="" class="img-thumbnail" style="max-height: 150px;">
                    </div>
                </div>
            `;

            container.appendChild(imageCard);
            additionalImageCount++;

            // Preview for additional images
            const fileInput = imageCard.querySelector('.additional-image-input');
            fileInput.addEventListener('change', function(e) {
                const file = e.target.files[0];
                if (file) {
                    const reader = new FileReader();
                    reader.onload = function(event) {
                        const preview = imageCard.querySelector('.additional-preview');
                        preview.querySelector('img').src = event.target.result;
                        preview.classList.remove('d-none');
                    };
                    reader.readAsDataURL(file);
                }
            });
        });

        function removeAdditionalImage(btn) {
            btn.closest('.additional-image-card').remove();
            additionalImageCount--;
        }

        // Real-time preview updates
        document.querySelector('input[name="Title"]').addEventListener('input', function() {
            document.getElementById('previewTitle').textContent = this.value || 'Tiêu đề đấu giá';
        });

        descriptionInput.addEventListener('input', function() {
            const text = this.value || 'Mô tả sẽ hiển thị ở đây...';
            document.getElementById('previewDescription').textContent =
                text.length > 100 ? text.substring(0, 100) + '...' : text;
        });

        document.querySelector('select[name="AuctionCategory"]').addEventListener('change', function() {
            document.getElementById('previewCategory').textContent =
                this.options[this.selectedIndex].text || 'Danh mục';
        });

        document.querySelector('input[name="StartingBid"]').addEventListener('input', function() {
            document.getElementById('previewBid').textContent = '$' + (this.value || '0');
        });

        // Form submission
        document.getElementById('createAuctionForm').addEventListener('submit', function(e) {
            const submitBtn = document.getElementById('submitBtn');
            const loadingOverlay = document.getElementById('loadingOverlay');

            submitBtn.disabled = true;
            submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang xử lý...';
            loadingOverlay.classList.remove('d-none');
        });

        // Set minimum date for start time
        const now = new Date();
        now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
        document.querySelector('input[name="StartTime"]').min = now.toISOString().slice(0, 16);
        document.querySelector('input[name="EndTime"]').min = now.toISOString().slice(0, 16);
    </script>

    <style>
        .upload-area {
            border: 2px dashed #dee2e6;
            border-radius: 0.5rem;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .upload-area:hover {
            border-color: #0d6efd;
            background-color: rgba(13, 110, 253, 0.05);
        }

        .upload-placeholder {
            min-height: 200px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }

        #mainImagePreview img {
            max-height: 300px;
            width: 100%;
            object-fit: cover;
        }

        .sticky-top {
            position: sticky;
        }

        #loadingOverlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.7);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 9999;
        }

        .additional-image-card {
            animation: slideIn 0.3s ease;
        }

        @@keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
}